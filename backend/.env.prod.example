DATABASE_URL=postgresql://user:password@db-host:5432/dbname

DEBUG=False
DJANGO_SECRET_KEY=replace-with-production-secret

DJANGO_SITE_NAME=CSLUSE
DJANGO_SITE_DOMAIN=example.com

ALLOWED_HOSTS=example.com,www.example.com
CORS_ALLOWED_ORIGINS=https://example.com,https://www.example.com
CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com
SESSION_COOKIE_DOMAIN=.example.com
CSRF_COOKIE_DOMAIN=.example.com
JWT_AUTH_COOKIE_DOMAIN=.example.com

S3_ACCESS_KEY=replace-with-s3-access-key
S3_SECRET_KEY=replace-with-s3-secret-key
S3_BUCKET_NAME=replace-with-bucket-name
S3_REGION=ap-southeast-1
S3_LOCATION=media
S3_CUSTOM_DOMAIN=

SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_SSL_REDIRECT=True

MICROSOFT_CLIENT_ID=replace-with-microsoft-client-id
MICROSOFT_CLIENT_SECRET=replace-with-microsoft-client-secret
MICROSOFT_TENANT_ID=replace-with-microsoft-tenant-id
MICROSOFT_AUTHORITY=https://login.microsoftonline.com
MICROSOFT_GRAPH_URL=https://graph.microsoft.com
MICROSOFT_ALLOWED_DOMAIN=example.com

LOGIN_REDIRECT_URL=https://example.com/dashboard/
LOGOUT_REDIRECT_URL=https://example.com/
FRONTEND_URL=https://example.com/

EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=no-reply@example.com
EMAIL_HOST_PASSWORD=replace-with-email-password

RUN_MIGRATIONS=true
RUN_COLLECTSTATIC=true
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=60
